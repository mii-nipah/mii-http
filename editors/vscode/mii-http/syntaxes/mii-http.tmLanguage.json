{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "mii-http",
  "scopeName": "source.mii-http",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#endpoint"
    },
    {
      "include": "#setup"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#types"
    },
    {
      "include": "#execRefs"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mii-http",
          "match": "^\\s*#.*$"
        }
      ]
    },
    "endpoint": {
      "patterns": [
        {
          "name": "keyword.other.method.mii-http",
          "match": "^\\s*(GET|POST|PUT|DELETE|PATCH)\\b"
        },
        {
          "name": "variable.parameter.path.mii-http",
          "match": ":[A-Za-z_][A-Za-z0-9_-]*(?::[A-Za-z][A-Za-z0-9_()|./-]*)?"
        }
      ]
    },
    "setup": {
      "patterns": [
        {
          "name": "keyword.control.setup.mii-http",
          "match": "^\\s*(VERSION|BASE|AUTH|JWT_VERIFIER|TOKEN_SECRET|MAX_BODY_SIZE|MAX_QUERY_PARAM_SIZE|MAX_HEADER_SIZE|TIMEOUT)\\b"
        },
        {
          "name": "storage.type.auth.mii-http",
          "match": "\\b(Bearer|ENV|HEADER)\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.mii-http",
          "match": "^\\s*(QUERY|HEADER|VAR|BODY)\\b"
        },
        {
          "name": "keyword.control.directive.mii-http",
          "match": "^\\s*(Response-Type|Exec):?"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.mii-http",
          "match": "\\b(int|float|boolean|bool|uuid|string|json|binary|form)\\b"
        },
        {
          "name": "constant.numeric.range.mii-http",
          "match": "\\b(?:int|float)\\([^)]*\\)"
        },
        {
          "name": "string.regexp.mii-http",
          "match": "/(?:\\\\.|[^/\\\\])*/"
        }
      ]
    },
    "execRefs": {
      "patterns": [
        {
          "name": "variable.other.reference.query.mii-http",
          "match": "%[A-Za-z_][A-Za-z0-9_-]*"
        },
        {
          "name": "variable.other.reference.path.mii-http",
          "match": ":[A-Za-z_][A-Za-z0-9_-]*"
        },
        {
          "name": "variable.other.reference.header.mii-http",
          "match": "\\^[A-Za-z_][A-Za-z0-9_-]*"
        },
        {
          "name": "variable.other.reference.var.mii-http",
          "match": "@[A-Za-z_][A-Za-z0-9_-]*"
        },
        {
          "name": "variable.other.reference.body.mii-http",
          "match": "\\$(?:\\.[A-Za-z_][A-Za-z0-9_-]*)*"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mii-http",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.mii-http"
            }
          ]
        },
        {
          "name": "string.quoted.single.mii-http",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.mii-http"
            }
          ]
        }
      ]
    }
  }
}
